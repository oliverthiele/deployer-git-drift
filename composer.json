{
    "name": "oliver-thiele/deployer-git-drift",
    "description": "Deployer recipe: detect and warn about direct server-side file changes before deployment",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Oliver Thiele",
            "email": "mail@oliver-thiele.de",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.4",
        "deployer/deployer": "^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "OliverThiele\\DeployerGitDrift\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OliverThiele\\DeployerGitDrift\\Tests\\": "tests/"
        }
    },
    "keywords": [
        "deployer",
        "deployment",
        "git",
        "drift",
        "server",
        "monitoring"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^13.2"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    }
}
